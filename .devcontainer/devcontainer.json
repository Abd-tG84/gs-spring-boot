{
  "name": "Spring Boot Dev Container",
  "image": "mcr.microsoft.com/devcontainers/java:21",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
        "version": "21",
        "installMaven": "true",
        "installGradle": "false"       
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "pivotal.vscode-spring-boot",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-maven",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "spgoding.javadoctools",
        "hbenl.vscode-test-explorer",
        "ryanluker.vscode-coverage-gutters",
        "shengchen.vscode-checkstyle"
      ]
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": [
    "mvn clean install || true",
    "echo 'nameserver 10.255.255.254' | sudo tee -a /etc/resolv.conf",
    "echo 'nameserver nssw01-tk.hitachi.co.jp' | sudo tee -a /etc/resolv.conf",
    "sudo apt-get update && sudo apt-get install -y gh"
  ],
  "remoteEnv": {
    "HTTP_PROXY": "http://umproxy.prx.intra.hitachi.co.jp:8080",
    "HTTPS_PROXY": "http://umproxy.prx.intra.hitachi.co.jp:8080"
  }
}

